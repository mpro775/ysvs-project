# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
MONGODB_URI=mongodb://localhost:27017/ysvs

# JWT
JWT_SECRET=your-super-secret-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@ysvs.org

# Storage
STORAGE_PROVIDER=local
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Cloudflare R2 (used when STORAGE_PROVIDER=r2)
R2_REGION=auto
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Example: https://cdn.ysvs.org
R2_PUBLIC_URL=

# Frontend URL (for redirects, fallback for CORS)
FRONTEND_URL=http://localhost:5173

# CORS: allowed origins - comma-separated (optional, overrides FRONTEND_URL for CORS in production)
# CORS_ORIGINS=https://admin.ysvs.smartagency-ye.com,https://ysvs.smartagency-ye.com,http://localhost:5173

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Newsletter
NEWSLETTER_DOUBLE_OPT_IN=false
NEWSLETTER_CONFIRM_TOKEN_TTL_HOURS=48
NEWSLETTER_SUBSCRIBE_RATE_LIMIT_PER_MINUTE=6
NEWSLETTER_UNSUBSCRIBE_RATE_LIMIT_PER_MINUTE=12

# Contact
CONTACT_NOTIFY_TO=support@ysvs.org
CONTACT_SUBMIT_RATE_LIMIT_PER_MINUTE=5
CONTACT_AUTO_ACK_ENABLED=false
